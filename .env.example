# Network
PORT=3000
HOST=0.0.0.0

# Optional persistent data directory. Railway normally supplies RAILWAY_VOLUME_MOUNT_PATH.
# DATA_DIR=C:\path\to\hex-settlers-data

# Security and proxy settings
HEX_AUTH_ATTEMPTS_PER_MINUTE=12
HEX_WS_MAX_PAYLOAD=50331648
HEX_ALLOWED_ORIGINS=
HEX_TRUST_PROXY=false

# Optional logging toggle retained by the TypeScript bootstrap
HEX_LOG_VERBOSE=false
