# The server does not automatically load this file. Copy these values into your
# shell, process manager, or hosting-provider environment.
HOST=0.0.0.0
PORT=3000
DATA_DIR=./data
HEX_TRUST_PROXY=false
HEX_ALLOWED_ORIGINS=
HEX_AUTH_ATTEMPTS_PER_MINUTE=12
HEX_WS_MAX_PAYLOAD=50331648

# Built-in administrator account:
#   Username: Benleethom
#   Player name: Ben
# Set a strong password here in Railway before deployment. When omitted on the
# first production start, a random temporary password is printed once in logs.
HEX_BUILTIN_ADMIN_ENABLED=true
HEX_ADMIN_PASSWORD=
# Set true for one restart only when the environment password should overwrite
# a password Ben changed from the in-game account screen.
HEX_ADMIN_FORCE_PASSWORD_SYNC=false

# Public account-recovery links. Use the exact public origin of the game.
HEX_PUBLIC_BASE_URL=
HEX_EMAIL_FROM=Hex Settlers <no-reply@example.com>

# Email delivery option 1: Resend API.
RESEND_API_KEY=

# Email delivery option 2: SMTP. Leave SMTP_HOST blank when using Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REQUIRE_TLS=true
SMTP_ALLOW_SELF_SIGNED=false
SMTP_TIMEOUT_MS=15000

# Simulation-only acceleration. Do not enable for normal hosted games.
AI_FAST=0
