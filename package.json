{
  "name": "hex-settlers",
  "version": "1.0.0",
  "private": true,
  "description": "Online hex-settlement strategy game with classic and seafaring maps, multiplayer, and AI opponents.",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:legacy": "node server.js",
    "build": "tsc -p tsconfig.bootstrap.json",
    "build:bootstrap": "tsc -p tsconfig.bootstrap.json",
    "test": "node --test",
    "test:integration": "node --test test/server.integration.test.js",
    "check": "tsc -p tsconfig.bootstrap.json && node --test && node --check server.js && node --check public/app.js",
    "electron:start": "electron .",
    "electron:dist": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "app.hexsettlers.desktop",
    "productName": "Hex Settlers",
    "files": [
      "electron-main.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
